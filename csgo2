            // Simple UI
            const caseNames = cases.map(c => c.name).join('\n');
            const targetCase = prompt("Enter EXACT Case Name to farm:\n" + caseNames);
            if (!targetCase || !items[targetCase]) return alert("Invalid case.");

            const targetItem = prompt("Stop when getting item containing name (e.g. 'Knife' or 'Dragon Lore'):");
            if (!targetItem) return;

            const speed = parseInt(prompt("Speed (ms delay between opens, min 10):", "50")) || 50;

            if (!confirm(`Start farming '${targetCase}' until '${targetItem}'? Press OK.`)) return;

            const noti = document.createElement('div');
