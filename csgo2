        win.mod_dupeSpecific = () => {
            const menu = document.getElementById('mod-menu');
            if (!menu) return;

            // Visual indication
            menu.style.opacity = '0.3';
            menu.style.pointerEvents = 'none';
            document.body.style.cursor = 'crosshair';

            // Add style for highlighting
            const styleId = 'mod-dupe-style';
            if (!document.getElementById(styleId)) {
                const s = document.createElement('style');
                s.id = styleId;
                s.innerHTML = `
                    .item:hover {
                        outline: 4px solid #a0f !important;
                        z-index: 10000 !important;
                        cursor: copy !important;
                        transform: scale(1.05);
                        box-shadow: 0 0 15px #a0f;
                    }
                `;
                document.head.appendChild(s);
            }

            function handleClick(e) {
                // Stop everything
                e.preventDefault();
                e.stopPropagation();
                e.stopImmediatePropagation();

                const itemEl = e.target.closest('.item');
                if (itemEl) {
                    const nameEl = itemEl.querySelector('.item-name');
                    let name = nameEl ? nameEl.innerText.trim() : null;

                    if (name) {
                        // Check if valid
                        let validName = name;

                        // 1. Try exact match
                        if (!items[validName]) {
                            // 2. Try cleanup (newlines/spaces)
                            const cleanName = name.replace(/\n/g, ' ').replace(/\s+/g, ' ').trim();
                            if (items[cleanName]) {
                                validName = cleanName;
                            } else {
                                // 3. Try to find the closest key in items database
                                // Many items like "Dragon Lore" might be "AWP | Dragon Lore (Factory New)"
                                // We need to check if 'name' is part of any item key
                                const found = Object.keys(items).find(k => k.includes(name) || name.includes(k));

                                if (found) {
                                    console.log(`Fuzzy match: "${name}" -> "${found}"`);
                                    validName = found;
                                } else {
                                    // 4. Force bypass if it exists in inventory already (trust the user's inventory)
                                    // "Dupe Inventory" works because it just copies the string from the array
                                    // So we should allow it if we can't verify it against DB but user clicked it
                                    console.warn(`Item "${name}" not found in DB, but exists in DOM. Duping anyway as raw string.`);
                                    validName = name;
                                }
                            }
                        }

                        // Small delay to allow browser to render confirm dialog cleanly
                        setTimeout(() => {
                            const countStr = prompt(`Duplicate "${validName}"? Enter amount:`, "1");
                            if (countStr !== null) {
                                const count = parseInt(countStr);
                                if (!isNaN(count) && count > 0) {
                                    for(let i=0; i<count; i++) user.inventory.push(validName);
                                    alert(`Duplicated ${count}x ${validName}`);
                                    game.emit("update");
                                }
                            }
                            cleanup();
                        }, 10);
                    } else {
                        alert("Could not find item name.");
                        cleanup();
                    }
                } else {
                    // Clicked outside item, just cancel
                    cleanup();
                }
            }

            function handleKey(e) {
                if (e.key === "Escape") cleanup();
            }

            function cleanup() {
                menu.style.opacity = '1';
                menu.style.pointerEvents = 'auto';
                document.body.style.cursor = 'default';
                document.removeEventListener('click', handleClick, true);
                document.removeEventListener('keydown', handleKey, true);
                const s = document.getElementById(styleId);
                if (s) s.remove();
            }

            // Use capture to ensure we get the event first
            document.addEventListener('click', handleClick, true);
            document.addEventListener('keydown', handleKey, true);
        };

