    // 0. CRITICAL CLEANUP (Before anything else)
    // -------------------------------------------------------------------------
    try {
        // Remove the problematic key that causes QuotaExceededError
        localStorage.removeItem('console-history');

        // Remove other non-essential keys if storage is full
        if (JSON.stringify(localStorage).length > 4500000) {
            console.warn("Storage nearly full! Cleaning up junk...");
            const keep = ['localsave', 'localuser', 'shop', 'flags', 'backup', 'backupid'];
            for (let i = localStorage.length - 1; i >= 0; i--) {
                const key = localStorage.key(i);
                if (!keep.includes(key)) localStorage.removeItem(key);
            }
        }
    } catch(e) {
        console.error("Storage Cleanup Failed:", e);
    }

    console.log("=== CSGO CLICKER MOD MENU v1.5 STARTING ===");

