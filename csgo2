            document.body.appendChild(noti);

            let running = true;
            noti.onclick = () => { running = false; noti.remove(); alert("Bot Stopped"); };

            const interval = setInterval(async () => {
                if (!running) { clearInterval(interval); noti.remove(); return; }

                // Check if we have the case
                if (!user.inventory.includes(targetCase)) {
                    user.inventory.push(targetCase);
                }

                const caseObj = items[targetCase];
                if (caseObj.keyName && !user.inventory.includes(caseObj.keyName)) {
                    user.inventory.push(caseObj.keyName);
                }

                // SIMULATE OPENING LOGIC
                // We pick a random item from the case content.
                // In real game, rarity logic is complex. Here we simplify for speed.
                const content = caseObj.content.items;
                const randomItemId = content[Math.floor(Math.random() * content.length)];

                // Add to inventory
                user.inventory.push(randomItemId);

                // Stats
                user.stats.opened_cases = (user.stats.opened_cases || 0) + 1;

                // Check win
                const wonItem = items[randomItemId];
                if (wonItem.name.includes(targetItem) || wonItem.type.includes(targetItem)) {
                    running = false;
                    clearInterval(interval);
                    noti.remove();
                    alert(`BOT FINISHED! Found: ${wonItem.name}`);
